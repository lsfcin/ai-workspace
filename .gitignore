# ============================================================
# AI-Workspace — .gitignore com whitelist
# Versiona apenas arquivos de sistema do workspace.
# Dados de projetos, fichas pessoais e materiais de aula
# ficam somente no ambiente local.
# ============================================================

# Ignorar tudo por padrão
*
**/*

# Permitir navegação em diretórios
!*/

# ── Raiz ────────────────────────────────────────────────────
!CLAUDE.md
!00_ESTRUTURA_DE_PASTAS.md
!README.md
!LICENSE
!.gitignore

# ── Contextos e specs (todos os níveis) ─────────────────────
!**/CONTEXT.md
!**/SPECS.md

# ── Meta: templates, tools, referências ─────────────────────
!meta/templates/
!meta/templates/*.md
!meta/tools/
!meta/tools/*.md
!meta/referencias/
!meta/referencias/clief-notes/
!meta/referencias/clief-notes/CONTEXT.md
!meta/referencias/clief-notes/*.pdf

# ── Hook de versionamento ────────────────────────────────────
!meta/hooks/
!meta/hooks/*.py
!meta/hooks/*.sh

# ── Scripts utilitários (Tier 0-2) ──────────────────────────
!meta/scripts/
!meta/scripts/*.py
.env

# ── dev/apptime — source code ───────────────────────────────
!dev/apptime/ROADMAP.md
!dev/apptime/HISTORY.md
!dev/apptime/CONTEXT.md
!dev/apptime/SPECS.md
!dev/apptime/lib/
!dev/apptime/lib/**
!dev/apptime/lib/data/
!dev/apptime/lib/data/**
!dev/apptime/android/app/src/main/kotlin/
!dev/apptime/android/app/src/main/kotlin/**
!dev/apptime/android/app/src/main/AndroidManifest.xml
!dev/apptime/android/app/src/main/res/values/styles.xml
!dev/apptime/android/app/src/main/res/mipmap-anydpi-v26/
!dev/apptime/android/app/src/main/res/mipmap-anydpi-v26/**
!dev/apptime/android/app/src/main/res/values/ic_launcher_background.xml
!dev/apptime/android/app/src/main/res/drawable/ic_launcher_foreground.png
!dev/apptime/pubspec.yaml
